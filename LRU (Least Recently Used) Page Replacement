def lru_page_replacement(pages, capacity):
    memory = []
    page_faults = 0
    
    print("\nLRU Execution:")
    for page in pages:
        if page not in memory:
            if len(memory) < capacity:
                memory.append(page)
            else:
                memory.pop(0) # Oldest referenced structurally drops out
                memory.append(page)
            page_faults += 1
            print(f"Page {page} -> Fault: {memory}")
        else:
            # Move the hit page to the end to mark it as most recently used
            memory.remove(page)
            memory.append(page)
            print(f"Page {page} -> Hit  : {memory}")
            
    print(f"Total Page Faults: {page_faults}")

lru_page_replacement([7, 0, 1, 2, 0, 3, 0, 4, 2, 3, 0, 3], capacity=3)
