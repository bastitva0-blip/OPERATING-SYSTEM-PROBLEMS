import threading
import time
import random

# Configuration parameters
WAITING_SEATS = 3      # Number of chairs in the waiting room
TOTAL_CUSTOMERS = 10   # Total customers that will visit today

class BarberShop:
    def __init__(self, seats):
        self.seats = seats
        self.waiting_customers = 0
        
        # Mutex to protect access to the shared state (waiting_customers count)
        self.mutex = threading.Lock()
        
        # Semaphore: Tracks available customers to wake up the barber
        self.customer_semaphore = threading.Semaphore(0)
        
        # Semaphore: Tracks barber availability for waiting customers
        self.barber_semaphore = threading.Semaphore(0)

    def barber_process(self):
        while True:
            print("💈 The barber is sleeping... 💤")
            # Wait until a customer arrives and signals
            self.customer_semaphore.acquire()
            
            # Access the waiting room to pick up a customer
            self.mutex.acquire()
            self.waiting_customers -= 1
            print(f"💈 Barber wakes up. Customers left in waiting room: {self.waiting_customers}")
            self.mutex.release()
            
            # Signal the customer that the barber is ready to cut hair
            self.barber_semaphore.release()
            
            # Simulate the haircut process
            print("💈 Barber is cutting hair... ✂️")
            time.sleep(random.uniform(0.5, 1.5))
            print("💈 Barber finished the haircut.")

    def customer_process(self, customer_id):
        # Customer arrives at random intervals
        time.sleep(random.uniform(0, 3))
        print(f"👤 Customer {customer_id} arrives at the shop.")
        
        # Protect shared space with mutex lock
        self.mutex.acquire()
        
        if self.waiting_customers < self.seats:
            # Sit down on an available chair
            self.waiting_customers += 1
            print(f"👤 Customer {customer_id} takes a seat. Total waiting: {self.waiting_customers}")
            
            # Signal the barber that a customer is ready
            self.customer_semaphore.release()
            
            # Release mutex lock before waiting for the barber
            self.mutex.release()
            
            # Wait for the barber to become available
            self.barber_semaphore.acquire()
            print(f"👤 Customer {customer_id} is getting their hair cut. 💇")
            
        else:
            # No seats available, leave the shop immediately
            print(f"🚪 No seats left. Customer {customer_id} leaves the shop. ❌")
            self.mutex.release()

# Main execution environment
if __name__ == "__main__":
    shop = BarberShop(seats=WAITING_SEATS)
    
    # Start the barber thread
    barber_thread = threading.Thread(target=shop.barber_process, daemon=True)
    barber_thread.start()
    
    # Create and start customer threads
    customer_threads = []
    for i in range(1, TOTAL_CUSTOMERS + 1):
        t = threading.Thread(target=shop.customer_process, args=(i,))
        customer_threads.append(t)
        t.start()
        
    # Wait for all customer threads to finish their execution
    for t in customer_threads:
        t.join()
        
    print("\n👋 All scheduled customers processed. Barber shop closing for the day!")
