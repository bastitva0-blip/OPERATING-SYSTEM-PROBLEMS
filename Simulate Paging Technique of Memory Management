def simulate_paging():
    memory_size = 256  # Total main memory bytes
    page_size = 16     # Frame/Page size bytes
    
    total_frames = memory_size // page_size
    
    # Mock Page Table mapping: Key (Page Number) -> Value (Frame Number)
    # Mapping arbitrary pages to physical frames
    page_table = {0: 2, 1: 5, 2: 1, 3: 7, 4: 11}
    
    print("--- Paging System Simulation ---")
    print(f"Total Memory Size: {memory_size} bytes | Page Size: {page_size} bytes")
    print("Page Table Map -> { Page: Frame } :", page_table)
    
    # Input simulating logical address request
    logical_address = 34  # Example binary pointer 
    
    # Address calculations
    page_number = logical_address // page_size
    offset = logical_address % page_size
    
    if page_number in page_table:
        frame_number = page_table[page_number]
        physical_address = (frame_number * page_size) + offset
        
        print(f"\nLogical Address: {logical_address}")
        print(f"Calculated -> Page Number: {page_number}, Offset: {offset}")
        print(f"Mapped Frame Number: {frame_number}")
        print(f"Resulting Physical Address: {physical_address}")
    else:
        print(f"\nPage Fault! Page {page_number} is not in physical RAM memory.")

simulate_paging()
